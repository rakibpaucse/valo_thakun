// Prisma schema for Anis Bhai — doctor portfolio + booking + community platform.
// SQLite for dev (single file), easy swap to Postgres for prod.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────
// ACCOUNTS & AUTH
// ─────────────────────────────────────────────────────────────────────

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("PATIENT") // SQLite has no enums — store as string
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  doctor      Doctor?
  patient     Patient?
  posts       Post[]
  comments    Comment[]
  reactions   Reaction[]
  sessions    Session[]
  accounts    Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────
// DOCTOR PROFILES
// ─────────────────────────────────────────────────────────────────────

model Doctor {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug            String   @unique
  title           String   // e.g. "Dr.", "Prof. Dr."
  headline        String   // short tagline
  bio             String   // markdown
  yearsExperience Int      @default(0)
  languages       String   // CSV: "English,Bangla,Hindi"
  consultationFee Int      @default(0) // BDT
  isMain          Boolean  @default(false)
  isAcceptingNew  Boolean  @default(true)
  avatarUrl       String?
  coverUrl        String?
  phone           String?
  whatsapp        String?
  rating          Float    @default(5.0)
  reviewCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  specializations DoctorSpecialization[]
  credentials     Credential[]
  services        DoctorService[]
  workingHours    WorkingHours[]
  timeOff         TimeOff[]
  slotOverrides   SlotOverride[]
  appointments    Appointment[]
  galleryImages   GalleryImage[]
}

model Specialization {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconKey     String?  // lucide icon key
  doctors     DoctorSpecialization[]
  services    Service[]
}

model DoctorSpecialization {
  doctorId         String
  specializationId String
  doctor           Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialization   Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@id([doctorId, specializationId])
}

model Credential {
  id          String   @id @default(cuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  kind        String   // "EDUCATION" | "CERTIFICATION" | "POSITION" | "AWARD"
  title       String
  institution String
  location    String?
  yearStart   Int?
  yearEnd     Int?
  description String?
  order       Int      @default(0)
}

model GalleryImage {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  order     Int      @default(0)
}

// ─────────────────────────────────────────────────────────────────────
// PATIENT PROFILES
// ─────────────────────────────────────────────────────────────────────

model Patient {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth   DateTime?
  phone         String?
  gender        String?
  insuranceType String?
  notes         String?
  createdAt     DateTime @default(now())

  appointments Appointment[]
}

// ─────────────────────────────────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────────────────────────────────

model Service {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String
  durationMinutes  Int      @default(30)
  bufferMinutes    Int      @default(5)
  price            Int      @default(0)
  iconKey          String?
  imageUrl         String?
  isFeatured       Boolean  @default(false)
  specializationId String?
  specialization   Specialization? @relation(fields: [specializationId], references: [id])

  doctors      DoctorService[]
  appointments Appointment[]
}

model DoctorService {
  doctorId  String
  serviceId String
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([doctorId, serviceId])
}

// ─────────────────────────────────────────────────────────────────────
// SCHEDULING
// ─────────────────────────────────────────────────────────────────────

model WorkingHours {
  id        String  @id @default(cuid())
  doctorId  String
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  weekday   Int     // 0=Sun … 6=Sat
  startTime String  // "09:00"
  endTime   String  // "13:00"

  @@index([doctorId, weekday])
}

model TimeOff {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
}

model SlotOverride {
  id         String   @id @default(cuid())
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  date       DateTime // date for the override
  startTime  String   // "10:30"
  endTime    String   // "11:00"
  isOpen     Boolean  @default(true) // false = block this slot
  note       String?
}

// ─────────────────────────────────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────────────────────────────────

// status: PENDING | CONFIRMED | COMPLETED | CANCELLED | NO_SHOW
model Appointment {
  id              String   @id @default(cuid())
  doctorId        String
  doctor          Doctor   @relation(fields: [doctorId], references: [id])
  serviceId       String
  service         Service  @relation(fields: [serviceId], references: [id])
  patientId       String?  // null when guest booking
  patient         Patient? @relation(fields: [patientId], references: [id])
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  startsAt        DateTime
  endsAt          DateTime
  status          String   @default("CONFIRMED")
  notes           String?
  insuranceType   String?
  cancelToken     String   @unique @default(cuid())
  reminderSentAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([doctorId, startsAt])
  @@index([patientId])
}

// ─────────────────────────────────────────────────────────────────────
// CONTENT / BLOG
// ─────────────────────────────────────────────────────────────────────

// status: DRAFT | SCHEDULED | PUBLISHED
model Post {
  id              String   @id @default(cuid())
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  title           String
  slug            String   @unique
  excerpt         String
  content         String   // markdown / rich text JSON
  coverImage      String?
  status          String   @default("PUBLISHED")
  publishedAt     DateTime?
  scheduledFor    DateTime?
  readingMinutes  Int      @default(3)
  views           Int      @default(0)
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categories PostCategory[]
  tags       PostTag[]
  comments   Comment[]
  reactions  Reaction[]

  @@index([status, publishedAt])
}

model Category {
  id    String         @id @default(cuid())
  name  String         @unique
  slug  String         @unique
  posts PostCategory[]
}

model PostCategory {
  postId     String
  categoryId String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]
}

model PostTag {
  postId String
  tagId  String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

// status: PENDING | APPROVED | REJECTED
model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  guestName String?
  body      String
  status    String   @default("APPROVED")
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, status])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  emoji     String   // "👍" | "❤️" | "🔥" | "💡"
  createdAt DateTime @default(now())

  @@index([postId, emoji])
}

model NewsletterSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?  // "footer" | "post-page"
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────
// CONTACT MESSAGES
// ─────────────────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
