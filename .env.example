# Copy to `.env` and fill in real values.
# This file is a TEMPLATE — never put real secrets here, it gets committed.

# ── Database ─────────────────────────────────────────────────────────
# Pooled connection string from Neon / Supabase / Vercel Postgres.
# Format: postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
DATABASE_URL=""

# Optional — non-pooled connection, used by `prisma migrate` / `prisma db push`.
# Neon and Supabase expose a separate direct URL; paste it here.
# If your provider doesn't, leave blank and Prisma will use DATABASE_URL.
DIRECT_URL=""

# ── Auth (NextAuth v5 / Auth.js) ─────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=""

# True when behind any reverse proxy (always true on Vercel).
AUTH_TRUST_HOST="true"

# Your deployed origin.
NEXTAUTH_URL="http://localhost:3000"
